# Copy this file to secrets.toml (in the same folder) for local development,
# or paste the DATABASE_URL into Streamlit Cloud → App Settings → Secrets.
#
# Both the public app AND admin dashboard must share the SAME DATABASE_URL
# so that inference logs written by one are visible to the other.
#
# Free PostgreSQL providers: https://neon.tech (recommended), https://supabase.com

DATABASE_URL = "postgresql://user:password@host/dbname?sslmode=require"
